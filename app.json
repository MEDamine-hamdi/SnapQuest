{
  "expo": {
    "name": "SnapQuest",
    "slug": "snapquest-mobile",
    "scheme": "snapquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0b0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapquest.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0b0f",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.snapquest.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "SnapQuest needs camera to validate challenges" }],
      ["expo-image-picker", { "photosPermission": "SnapQuest needs photos for challenge validation" }]
    ]
  }
}