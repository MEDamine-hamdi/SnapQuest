{
  "expo": {
    "name": "SnapQuest",
    "slug": "snapquest-mobile",
    "scheme": "snapquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0b0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapquest.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0b0f",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.snapquest.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "SnapQuest needs camera to validate challenges"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapQuest needs photos for challenge validation"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc6e0a50-c6f2-4081-9996-99df230e1d0e"
      }
    }
  }
}
